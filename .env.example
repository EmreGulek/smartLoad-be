# Local: cp .env.example .env and fill values (.env is gitignored).
# Spring loads this file via spring.config.import in application.properties.
#
# Generate JWT (Base64 — required for login):
#   openssl rand -base64 32
#
# Render / production: use Environment Variables with the UPPER_SNAKE names
# listed in comments below (Spring Boot relaxed binding).

# Database
spring.datasource.url=jdbc:postgresql://localhost:5432/smartload
spring.datasource.username=smartload
spring.datasource.password=smartload_dev
# Render equivalents: SPRING_DATASOURCE_URL, SPRING_DATASOURCE_USERNAME, SPRING_DATASOURCE_PASSWORD

# JWT (replace before running locally)
security.jwt.secret-key=REPLACE_ME_openssl_rand_base64_32
security.jwt.expiration-time=3600000
# Render: SECURITY_JWT_SECRET_KEY, SECURITY_JWT_EXPIRATION_TIME

# Mail — production (Render free): use Resend HTTP API (SMTP 587 is blocked on free tier)
# https://resend.com → API Keys → create key
RESEND_API_KEY=
SMARTLOAD_MAIL_FROM=SmartLoad <onboarding@resend.dev>

# Optional local SMTP (Gmail App Password) — fallback if RESEND_API_KEY is empty
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=
spring.mail.password=

# CORS — add Cloudflare Pages URL when deploying
smartload.cors.allowed-origins=http://localhost:5173,http://localhost:5174
# Render: CORS_ALLOWED_ORIGINS=https://your-app.pages.dev
